# ============================================
# AI Medical Consultant - Environment Config
# ============================================

# --- LLM Configuration (DeepSeek) ---
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# --- Embedding Model (通义千问/DashScope) ---
EMBEDDING_API_KEY=your-qianwen-embedding-api-key
EMBEDDING_MODEL=text-embedding-v1

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/medical_consultant
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/medical_consultant

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- FAISS ---
FAISS_INDEX_PATH=./data/faiss_index
VECTOR_DIMENSION=1536

# --- JWT ---
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Knowledge Base ---
MEDICAL_KB_PATH=./data/medical_kb
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K_RETRIEVAL=5
